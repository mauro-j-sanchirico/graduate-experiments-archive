@article{so_codedprivateml:_2019,
	title = {{CodedPrivateML}: {A} {Fast} and {Privacy}-{Preserving} {Framework} for {Distributed} {Machine} {Learning}},
	shorttitle = {{CodedPrivateML}},
	url = {http://arxiv.org/abs/1902.00641},
	abstract = {How to train a machine learning model while keeping the data private and secure? We present CodedPrivateML, a fast and scalable approach to this critical problem. CodedPrivateML keeps both the data and the model information-theoretically private, while allowing efficient parallelization of training across distributed workers. We characterize CodedPrivateML's privacy threshold and prove its convergence for logistic (and linear) regression. Furthermore, via experiments over Amazon EC2, we demonstrate that CodedPrivateML can provide an order of magnitude speedup (up to \${\textbackslash}sim 34{\textbackslash}times\$) over the state-of-the-art cryptographic approaches.},
	urldate = {2021-01-10},
	journal = {arXiv:1902.00641 [cs, math, stat]},
