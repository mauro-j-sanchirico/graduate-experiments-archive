   3.8014302785258317`*^9}, {3.801574584599557*^9, 3.801574633850349*^9}, 
   3.801575918010518*^9, {3.801576499546204*^9, 3.801576501955118*^9}, {
   3.8015765487269373`*^9, 3.801576550711616*^9}, {3.801576829513978*^9, 
   3.801576847256485*^9}, {3.8018470418372507`*^9, 3.801847177345005*^9}, {
   3.8044644651710286`*^9, 3.8044644653784657`*^9}, {3.8044645233637867`*^9, 
   3.804464523954204*^9}, {3.8044645715868073`*^9, 3.804464624542194*^9}, {
   3.804464681642452*^9, 3.8044647145823717`*^9}, {3.8044647602841473`*^9, 
