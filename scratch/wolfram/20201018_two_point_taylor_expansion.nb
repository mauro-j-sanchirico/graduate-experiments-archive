Cell[CellGroupData[{
Cell["Two-Point Taylor Expansion", "DemoTitle",
 CellChangeTimes->{{3.8014279662513*^9, 3.80142797010579*^9}, {
  3.8015749392416277`*^9, 
  3.80157494631111*^9}},ExpressionUUID->"39338540-a151-458f-9cb2-\
428cce649034"],

Cell[CellGroupData[{

Cell["", "InitializationSection",ExpressionUUID->"b9454ebf-526b-41e4-bb48-41c6eaca9671"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TwoPointTaylor", "[", 
   RowBox[{"f_", ",", "a_", ",", "b_", ",", "0"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"TwoPointTaylor", "[", 
    RowBox[{"f", ",", "a", ",", "b", ",", "0"}], "]"}], "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"coeffs", ",", "c0", ",", "d0", ",", "linf"}], "}"}], ",", 
     RowBox[{
      RowBox[{"linf", "=", 
       RowBox[{
        RowBox[{"c0", "+", 
         RowBox[{"d0", " ", "#"}]}], " ", "&"}]}], ";", 
      RowBox[{"coeffs", "=", 
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"f", "[", "a", "]"}], "\[Equal]", 
            RowBox[{"linf", "[", "a", "]"}]}], ",", 
           RowBox[{
            RowBox[{"f", "[", "b", "]"}], "\[Equal]", 
            RowBox[{"linf", "[", "b", "]"}]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"c0", ",", "d0"}], "}"}]}], "]"}]}], ";", 
      RowBox[{"linf", "/.", 
       RowBox[{"coeffs", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}]}], "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.801428554394148*^9, 3.8014285558701353`*^9}, 
   3.8015745020229816`*^9, 3.804461310785801*^9, {3.804470875477621*^9, 
   3.804470877305729*^9}},
 CellID->34359806,ExpressionUUID->"bcd820b2-f1b6-44e4-8302-23bb928f6059"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TwoPointTaylor", "[", 
   RowBox[{"f_", ",", "a_", ",", "b_", ",", "n_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"TwoPointTaylor", "[", 
    RowBox[{"f", ",", "a", ",", "b", ",", "n"}], "]"}], "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"coeffs", ",", 
       RowBox[{"dfnm1", "=", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"f", "[", "x", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "n"}], "}"}]}], "]"}]}], ",", "newterm", ",", 
       "d2pTnm1", ",", "c", ",", "d"}], "}"}], ",", 
     RowBox[{
      RowBox[{"newterm", " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"c", "+", 
           RowBox[{"d", " ", "#"}]}], ")"}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"#", "-", "a"}], ")"}], 
            RowBox[{"(", 
             RowBox[{"#", "-", "b"}], ")"}]}], ")"}], "n"]}], "&"}]}], ";", 
      RowBox[{"d2pTnm1", "=", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"newterm", "[", "x", "]"}], "+", 
          RowBox[{
           RowBox[{"TwoPointTaylor", "[", 
            RowBox[{"f", ",", "a", ",", "b", ",", 
             RowBox[{"n", "-", "1"}]}], "]"}], "[", "x", "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "n"}], "}"}]}], "]"}]}], ";", 
      RowBox[{"coeffs", "=", 
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"dfnm1", "\[Equal]", "d2pTnm1"}], ")"}], "/.", 
            RowBox[{"x", "\[Rule]", "a"}]}], ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"dfnm1", "\[Equal]", "d2pTnm1"}], ")"}], "/.", 
            RowBox[{"x", "\[Rule]", "b"}]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"c", ",", "d"}], "}"}]}], "]"}]}], ";", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"newterm", "[", "#", "]"}], "+", 
          RowBox[{
           RowBox[{"TwoPointTaylor", "[", 
            RowBox[{"f", ",", "a", ",", "b", ",", 
             RowBox[{"n", "-", "1"}]}], "]"}], "[", "#", "]"}]}], ")"}], "/.", 
        RowBox[{"coeffs", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], "&"}]}]}], "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.801428554394148*^9, 3.8014285558701353`*^9}, {
   3.8015745020229816`*^9, 3.801574506413281*^9}, 3.804461399264157*^9, {
